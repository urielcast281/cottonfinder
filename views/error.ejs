<div class="error-page">
  <div class="container">
    <div class="error-content">
      <div class="error-icon">
        <% if (error.status === 404) { %>
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#9a8b7e" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <% } else { %>
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#c4835a" stroke-width="1.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <% } %>
      </div>
      <h1><%= error.status %> — <%= error.message %></h1>
      <% if (error.details) { %>
      <p><%= error.details %></p>
      <% } %>
      <div class="error-actions">
        <a href="/" class="btn btn-primary">Go Home</a>
        <a href="/search" class="btn btn-outline">Browse Products</a>
      </div>
    </div>
  </div>
</div>
